NODE_ENV=production
PORT=3000

# VerdiFlows — Webhooks externos (dominio público melisystems.com + UUID del nodo Webhook)
WEBHOOK_URL=http://verdi-flows.melisystems.com/webhook/a07945ab-fb80-406d-bcb3-4c8b10d9ee1b
WEBHOOK_VALIDATE_URL=http://verdi-flows.melisystems.com/webhook/2f6ec8a1-b435-4c68-8d89-6f80d088b5a6

# Basic Auth configurada en el nodo Webhook de VerdiFlows
