NODE_ENV=production
PORT=3000

# VerdiFlows — Webhooks de producción (path-based, no UUID)
WEBHOOK_VALIDATE_URL=https://api.mercadolibre.com/workspace/genai/verdi-flows/webhook/incapacidades-validar-driver/external
WEBHOOK_URL=https://api.mercadolibre.com/workspace/genai/verdi-flows/webhook/incapacidades-registro/external

# VerdiFlows — Webhooks de testing (misma estructura, sin BQ INSERT real)
WEBHOOK_VALIDATE_URL_TEST=https://api.mercadolibre.com/workspace/genai/verdi-flows/webhook/incapacidades-validar-driver-test/external
WEBHOOK_URL_TEST=https://api.mercadolibre.com/workspace/genai/verdi-flows/webhook/incapacidades-registro-test/external

# Header Auth configurado en el nodo Webhook de VerdiFlows
WEBHOOK_SECRET=REEMPLAZAR_CON_EL_SECRET

# Activar para apuntar a webhooks de testing (omitir en producción)
# TEST_MODE=true
